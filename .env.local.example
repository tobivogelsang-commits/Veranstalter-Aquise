NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Project Settings -> API Keys -> "secret" (früher "service_role"). NUR serverseitig,
# nie an den Browser senden. Nötig für Band-E-Mail-Zugangsdaten (SMTP/IMAP-Passwort).
SUPABASE_SERVICE_ROLE_KEY=

# serpapi.com Private API Key (für "Kontakt vervollständigen"), optional
SERPAPI_KEY=

# console.anthropic.com API Key (für die KI-Plausibilitätsprüfung bei
# "Kontakt vervollständigen" - erkennt Aggregator-/Ticket-Seiten, die nicht
# vom Veranstalter selbst betrieben werden). Optional: ohne Key wird die
# Prüfung übersprungen, der Rest von "Kontakt vervollständigen" läuft normal.
ANTHROPIC_API_KEY=

# Web-Push-Schlüsselpaar für die Team-App. Einmalig erzeugen mit:
# node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Öffentlicher CalDAV/iCal-Export des Proberaum-Kalenders (z. B. Nextcloud-
# Freigabelink mit "?export"), optional. Zeigt Belegungstermine in beiden
# In-App-Kalendern (Desktop + Team-App) an, fließt aber nicht ins private
# .ics-Kalender-Abo der Bands ein.
PROBERAUM_ICAL_URL=
