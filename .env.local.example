NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Project Settings -> API Keys -> "secret" (früher "service_role"). NUR serverseitig,
# nie an den Browser senden. Nötig für Band-E-Mail-Zugangsdaten (SMTP/IMAP-Passwort).
SUPABASE_SERVICE_ROLE_KEY=

# serpapi.com Private API Key (für "Kontakt vervollständigen"), optional
SERPAPI_KEY=

# Web-Push-Schlüsselpaar für die Team-App. Einmalig erzeugen mit:
# node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
